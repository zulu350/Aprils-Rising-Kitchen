# Supabase / Postgres (required for orders on Netlify)
# Use the connection string from Supabase → Project Settings → Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
# Optional: set false only for local Postgres without SSL
# DATABASE_SSL=false

# Kitchen admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-long-random-string
PICKUP_ADDRESS=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ORDER_NOTIFY_EMAIL=info@aprilsrisingkitchen.com
EMAIL_CUSTOMER_CONFIRM=true

# Public site URL (Netlify domain or custom)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
