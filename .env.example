# SQLite database (path relative to project root)
DATABASE_URL="file:./data/ark.db"

# Kitchen admin login password
ADMIN_PASSWORD=change-me

# Secret used to sign admin session cookies (use a long random string)
SESSION_SECRET=generate-a-long-random-string

# Shown only after pickup orders (never on public marketing pages)
PICKUP_ADDRESS=

# --- Email (new-order notifications) ---
# Required together to enable sending:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional from-address (defaults to SMTP_USER)
SMTP_FROM=
# Kitchen inbox (defaults to info@aprilsrisingkitchen.com)
ORDER_NOTIFY_EMAIL=info@aprilsrisingkitchen.com
# Set to "false" to skip customer confirmation emails
EMAIL_CUSTOMER_CONFIRM=true
# Used in email links (admin + order confirmation URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
