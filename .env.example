# Supabase / Postgres (required for orders on Netlify)
#
# IMPORTANT: Free Supabase "direct" hosts (db.xxxxx.supabase.co) are often
# IPv6-only. Home networks without IPv6 get P1001 "Can't reach database".
# Use the Session pooler URI instead (IPv4):
#
# Supabase → Project Settings → Database → Connect → Session pooler
# Format looks like:
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require
#
# User must be "postgres.PROJECT_REF" (not just "postgres").
# Port 5432 = Session (best for Prisma migrate). Port 6543 = Transaction (app-only).
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"
# Optional: set false only for local Postgres without SSL
# DATABASE_SSL=false

# Kitchen admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-long-random-string
PICKUP_ADDRESS=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional display name + email. Either bare email or: Name <email@domain>
# (Do not leave a lone trailing > — app builds the From header cleanly.)
SMTP_FROM=April's Rising Kitchen <info@aprilsrisingkitchen.com>
ORDER_NOTIFY_EMAIL=info@aprilsrisingkitchen.com
EMAIL_CUSTOMER_CONFIRM=true

# Public site URL — used in customer/kitchen order emails ("View your order")
# Must be your real domain in production (no trailing slash):
NEXT_PUBLIC_SITE_URL=https://www.aprilsrisingkitchen.com
